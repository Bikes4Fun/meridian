          "content": {
            "size": 10292,
            "compression": 0,
            "mimeType": "text/html",
            "text": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Chat</title>\n    <style>\n        * { box-sizing: border-box; }\n        body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, sans-serif; height: 100vh; display: flex; flex-direction: column; background: #f5f5f5; }\n        .header { display: flex; align-items: center; padding: 12px 16px; background: #fff; border-bottom: 1px solid #eee; }\n        .header .avatar { width: 40px; height: 40px; border-radius: 50%; background: #ddd; margin-right: 12px; }\n        .header .info { flex: 1; }\n        .header .name { font-weight: 600; font-size: 16px; color: #111; }\n        .header .status { font-size: 13px; color: #666; }\n        .messages { flex: 1; overflow-y: auto; padding: 16px; display: flex; flex-direction: column; gap: 8px; }\n        .bubble { max-width: 75%; padding: 10px 14px; border-radius: 18px; font-size: 15px; line-height: 1.4; word-wrap: break-word; }\n        .bubble.out { align-self: flex-start; background: #007AFF; color: #fff; border-bottom-left-radius: 4px; }\n        .bubble.in { align-self: flex-end; background: #e9e9eb; color: #111; border-bottom-right-radius: 4px; }\n        .bubble .time { font-size: 11px; opacity: 0.8; margin-top: 4px; }\n        .input-row { display: flex; align-items: center; gap: 8px; padding: 12px 16px; background: #fff; border-top: 1px solid #eee; }\n        .input-row input { flex: 1; padding: 12px 16px; border: 1px solid #ddd; border-radius: 20px; font-size: 15px; outline: none; }\n        .input-row input:focus { border-color: #007AFF; }\n        .input-row button { padding: 12px 20px; background: #007AFF; color: #fff; border: none; border-radius: 20px; font-size: 15px; cursor: pointer; }\n        .input-row button:disabled { background: #ccc; cursor: not-allowed; }\n        .error { padding: 12px; background: #fee; color: #c00; font-size: 14px; }\n    </style>\n</head>\n<body>\n    <div class=\"header\">\n        <div class=\"avatar\"></div>\n        <div class=\"info\">\n            <div class=\"name\" id=\"recipientName\">Messaging with …</div>\n            <div class=\"status\" id=\"status\">Connecting…</div>\n            <div id=\"loggedInAs\" style=\"font-size: 12px; color: #888; margin-top: 4px;\">Logged in messaging as …</div>\n        </div>\n    </div>\n    <div class=\"messages\" id=\"messages\"></div>\n    <div class=\"input-row\" id=\"inputRow\" style=\"display: none;\">\n        <input type=\"text\" id=\"msgInput\" placeholder=\"Type a message here\">\n        <button type=\"button\" id=\"sendBtn\">Send</button>\n    </div>\n    <div id=\"error\" class=\"error\" style=\"display: none;\"></div>\n    <script>\n(function () {\n    'use strict';\n    var API_URL = 'http://localhost:8080';\n    if (!API_URL.startsWith('http')) API_URL = '';\n\n    var q = {};\n    (window.location.search || '').replace(/^\\?/, '').split('&').forEach(function (p) {\n        var kv = p.split('=');\n        if (kv.length >= 2) q[decodeURIComponent(kv[0])] = decodeURIComponent(kv[1].replace(/\\+/g, ' '));\n    });\n    var recipientSb = (q.sendbird_user_id || '').trim();\n    var recipientName = (q.display_name || '').trim() || 'Contact';\n\n    var messagesEl = document.getElementById('messages');\n    var msgInput = document.getElementById('msgInput');\n    var sendBtn = document.getElementById('sendBtn');\n    var inputRow = document.getElementById('inputRow');\n    var statusEl = document.getElementById('status');\n    var recipientNameEl = document.getElementById('recipientName');\n    var errorEl = document.getElementById('error');\n\n    document.getElementById('recipientName').textContent = 'Messaging with ' + recipientName;\n\n    function log(msg, data) {\n        console.log('[chat] ' + msg, data !== undefined ? data : '');\n    }\n    function logErr(msg, err) {\n        console.error('[chat] ' + msg, err !== undefined ? err : '');\n    }\n    function showError(msg) {\n        logErr('showError', msg);\n        errorEl.textContent = msg || 'Error';\n        errorEl.style.display = 'block';\n        inputRow.style.display = 'flex';\n    }\n\n    function appendBubble(text, isSelf, ts) {\n        var div = document.createElement('div');\n        div.className = 'bubble ' + (isSelf ? 'out' : 'in');\n        div.innerHTML = (text || '') + '<div class=\"time\">' + (ts || '') + '</div>';\n        messagesEl.appendChild(div);\n        messagesEl.scrollTop = messagesEl.scrollHeight;\n    }\n\n    function setStatus(t) { if (statusEl) statusEl.textContent = t || ''; }\n\n    if (!recipientSb) {\n        showError('Missing sendbird_user_id');\n        setStatus('Error');\n        return;\n    }\n\n    function loadConfig() {\n        return fetch(API_URL + '/api/chat/config', { credentials: 'include' }).then(function (r) {\n            if (!r.ok) { logErr('Config failed', r.status); throw new Error('Config failed'); }\n            return r.json();\n        });\n    }\n    function loadToken() {\n        return fetch(API_URL + '/api/chat/token', {\n            method: 'POST',\n            headers: { 'Content-Type': 'application/json' },\n            credentials: 'include',\n            body: JSON.stringify({})\n        }).then(function (r) {\n            if (!r.ok) return r.json().then(function (d) { logErr('Token failed', d); throw new Error(d.error || 'Token failed'); });\n            return r.json();\n        });\n    }\n\n    var sb = null;\n    var currentChannel = null;\n\n    Promise.all([loadConfig(), loadToken()])\n        .then(function (results) {\n            log('config and token loaded');\n            var config = results[0];\n            var tokenData = results[1];\n            var loggedInEl = document.getElementById('loggedInAs');\n            if (loggedInEl) loggedInEl.textContent = 'Logged in messaging as ' + (tokenData.display_name || tokenData.sendbird_user_id || '…');\n            if (!config.app_id || !tokenData.sendbird_user_id || !tokenData.session_token) {\n                throw new Error('Missing config');\n            }\n            var sdkUrl = 'https://cdn.jsdelivr.net/npm/@sendbird/chat@4/+esm';\n            var groupUrl = 'https://cdn.jsdelivr.net/npm/@sendbird/chat@4/groupChannel/+esm';\n            return import(sdkUrl).then(function (chatMod) {\n                return import(groupUrl).then(function (groupMod) {\n                    sb = chatMod.default.init({\n                        appId: config.app_id,\n                        modules: [new groupMod.GroupChannelModule()],\n                        localCacheEnabled: false\n                    });\n                    var connectionHandler = new chatMod.ConnectionHandler({\n                        onConnected: function (userId) { log('ConnectionHandler: connected', userId); },\n                        onDisconnected: function (userId) { log('ConnectionHandler: disconnected', userId); },\n                        onReconnectStarted: function () { log('ConnectionHandler: reconnect started'); },\n                        onReconnectSucceeded: function () { log('ConnectionHandler: reconnect succeeded'); },\n                        onReconnectFailed: function () { logErr('ConnectionHandler: reconnect failed'); },\n                        onConnectionLost: function () { logErr('ConnectionHandler: connection lost'); }\n                    });\n                    sb.addConnectionHandler('meridian-chat', connectionHandler);\n                    return sb.connect(tokenData.sendbird_user_id, tokenData.session_token);\n                });\n            });\n        })\n        .then(function () {\n            log('Sendbird connected');\n            setStatus('Opening chat…');\n            return sb.groupChannel.createChannel({\n                invitedUserIds: [recipientSb],\n                isDistinct: true,\n                name: 'Family'\n            });\n        })\n        .then(function (channel) {\n            currentChannel = channel;\n            log('Channel ready', channel.url || channel.channelUrl);\n            setStatus('1:1 chat');\n            inputRow.style.display = 'flex';\n            sendBtn.onclick = sendMessage;\n            msgInput.onkeydown = function (e) { if (e.key === 'Enter') sendMessage(); };\n            var query = channel.createPreviousMessageListQuery ? channel.createPreviousMessageListQuery({ limit: 50 }) : null;\n            if (query && query.load) {\n                return query.load().then(function (list) {\n                    var msgs = Array.isArray(list) ? list : [];\n                    for (var i = 0; i < msgs.length; i++) {\n                        var m = msgs[i];\n                        var txt = (m.message || '').trim();\n                        if (!txt) continue;\n                        var isSelf = m.sender && m.sender.userId === sb.currentUser.userId;\n                        var ts = m.createdAt ? new Date(m.createdAt).toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' }) : '';\n                        appendBubble(txt, isSelf, ts);\n                    }\n                }).catch(function (loadErr) {\n                    logErr('Load messages failed (send still works)', loadErr);\n                    setStatus('Loaded with errors. You can still send.');\n                });\n            }\n            return Promise.resolve();\n        })\n        .catch(function (err) {\n            logErr('Channel error', err);\n            showError('Channel error: ' + (err && err.message ? err.message : String(err)));\n            setStatus('Error');\n        });\n\n    function sendMessage() {\n        var text = (msgInput && msgInput.value || '').trim();\n        if (!text || !currentChannel) return;\n        sendBtn.disabled = true;\n        currentChannel.sendUserMessage({ message: text })\n            .onSucceeded(function (m) {\n                log('Message sent');\n                var ts = m.createdAt ? new Date(m.createdAt).toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' }) : '';\n                appendBubble(text, true, ts);\n                if (msgInput) msgInput.value = '';\n            })\n            .onFailed(function (err) {\n                logErr('Send failed', err);\n                showError('Send failed: ' + (err && err.message ? err.message : err));\n            })\n            .finally(function () { sendBtn.disabled = false; });\n    }\n})();\n    </script>\n</body>\n</html>\n"
          },
